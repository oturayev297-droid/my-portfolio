# DATABASE_URL=postgres://user:password@host:5432/db_name
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=
DB_PORT=

# --- AI & INTEGRATIONS ---
GEMINI_API_KEY=
TELEGRAM_BOT_TOKEN=
